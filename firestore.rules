rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isTrainer() {
      return isSignedIn() &&
             (request.auth.token.email == 'youssf.rehem@revibe.me' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer'));
    }
    
    function isTrainerOrOwner(uid) {
      return isTrainer() || isOwner(uid);
    }

    // ============================================
    // Users Collection
    // ============================================
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isSignedIn();
      
      // Users can create their own profile
      allow create: if isOwner(userId) && 
                       request.resource.data.uid == userId;
      
      // Users can update their own profile (except role)
      // Trainers can update any user's profile (including role changes)
      allow update: if isOwner(userId) && 
                       (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
                       isTrainer();
      
      // Only trainers can delete users
      allow delete: if isTrainer();
    }

    // ============================================
    // Materials Collection
    // ============================================
    match /materials/{materialId} {
      // Everyone authenticated can read materials
      allow read: if isSignedIn();
      
      // Only trainers can create, update, or delete materials
      allow create, update, delete: if isTrainer();
    }

    // ============================================
    // Annotations Collection
    // ============================================
    match /annotations/{annotationId} {
      // Everyone authenticated can read annotations
      allow read: if isSignedIn();
      
      // Only trainers can create, update, or delete annotations
      allow create, update, delete: if isTrainer();
    }

    // ============================================
    // Progress Collection
    // ============================================
    match /progress/{progressId} {
      // Users can read their own progress
      // Trainers can read all progress records
      // (resource == null lets a get() on a not-yet-created doc resolve
      // instead of erroring on resource.data)
      allow read: if isSignedIn() &&
                     (resource == null ||
                      resource.data.uid == request.auth.uid ||
                      isTrainer());
      
      // Users can create/update their own progress
      // Document ID must match pattern: {uid}_{materialId}
      allow create: if isSignedIn() && 
                       request.resource.data.uid == request.auth.uid &&
                       progressId == request.auth.uid + '_' + request.resource.data.materialId;
      
      allow update: if isSignedIn() &&
                       resource.data.uid == request.auth.uid &&
                       request.resource.data.uid == request.auth.uid &&
                       progressId == request.auth.uid + '_' + request.resource.data.materialId;

      // Only trainers can delete progress records
      allow delete: if isTrainer();
    }

    // ============================================
    // Feedback Collection
    // ============================================
    match /feedback/{feedbackId} {
      // Feedback is private: only the author or a trainer can read it.
      // (resource == null lets the pre-submit get() on a not-yet-created
      // doc resolve instead of erroring on resource.data — which was
      // blocking trainees' first feedback submission.)
      allow read: if isSignedIn() &&
                     (resource == null ||
                      resource.data.uid == request.auth.uid ||
                      isTrainer());

      // Users can create/update their own feedback
      // Document ID must match pattern: {uid}_{materialId}
      allow create: if isSignedIn() &&
                       request.resource.data.uid == request.auth.uid &&
                       feedbackId == request.auth.uid + '_' + request.resource.data.materialId &&
                       request.resource.data.rating is number &&
                       request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
                       (!('comment' in request.resource.data) ||
                        request.resource.data.comment.size() <= 500);

      allow update: if isSignedIn() &&
                       resource.data.uid == request.auth.uid &&
                       request.resource.data.uid == request.auth.uid &&
                       feedbackId == request.auth.uid + '_' + request.resource.data.materialId &&
                       request.resource.data.rating is number &&
                       request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
                       (!('comment' in request.resource.data) ||
                        request.resource.data.comment.size() <= 500);
      
      // Only trainers can delete feedback
      allow delete: if isTrainer();
    }

    // ============================================
    // Deny all other collections by default
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
